# ===================================================================
# SchoolSaaS Backend — Environment Variables
# ===================================================================
# Copy this file to .env and fill in real values.
# Never commit .env to Git.
# ===================================================================

# -------------------------------------------------------------------
# Database (Railway provides this automatically as DATABASE_URL)
# -------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/schoolsaas
SPRING_DATASOURCE_USERNAME=schoolsaas
SPRING_DATASOURCE_PASSWORD=your_secure_db_password

# -------------------------------------------------------------------
# JWT Authentication
# -------------------------------------------------------------------
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your_super_long_jwt_secret_key_min_32_chars_generate_with_openssl
JWT_ACCESS_TOKEN_EXPIRATION_MS=3600000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

# -------------------------------------------------------------------
# Mail (Gmail SMTP or AWS SES)
# -------------------------------------------------------------------
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# -------------------------------------------------------------------
# Paystack Payments
# -------------------------------------------------------------------
# Use test keys for development: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
# Override base URL per environment (defaults to https://api.paystack.co)
PAYSTACK_BASE_URL=https://api.paystack.co

# -------------------------------------------------------------------
# Flutterwave Payments
# -------------------------------------------------------------------
# Use test keys for development: https://dashboard.flutterwave.com/dashboard/settings/apis
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_flutterwave_secret_key
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_flutterwave_public_key
# Override base URL per environment (defaults to https://api.flutterwave.com/v3)
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

# -------------------------------------------------------------------
# OpenAI (AI Tutor)
# -------------------------------------------------------------------
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-3.5-turbo

# -------------------------------------------------------------------
# CORS — Frontend Origin(s)
# -------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-app.vercel.app

# -------------------------------------------------------------------
# File Uploads / Storage
# -------------------------------------------------------------------
# For MVP, you can store files locally or use AWS S3 / Cloudflare R2
# AWS_S3_BUCKET=schoolsaas-uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-1

# -------------------------------------------------------------------
# Spring Profiles
# -------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev
# For Railway/VPS production: set to "prod"

# -------------------------------------------------------------------
# Server
# -------------------------------------------------------------------
SERVER_PORT=8080

# -------------------------------------------------------------------
# Admin Seeder (dev profile only)
# -------------------------------------------------------------------
# These are used by DataSeeder.java when SPRING_PROFILES_ACTIVE=dev
# PLATFORM_ADMIN_EMAIL=admin@schoolsaas.com
# PLATFORM_ADMIN_PASSWORD=ChangeMe123!
